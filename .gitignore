# Root .gitignore for calendar-hub (backend + frontend)

# ----- Node / frontend -----
node_modules/
/dist/
/tmp/
/out-tsc/
/bazel-out/
/.angular/cache/
/.sass-cache/
/connect.lock
/coverage/
/libpeerconnection.log
/testem.log
/typings/
__screenshots__/
/npm-debug.log
/yarn-error.log

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# OS
.DS_Store
Thumbs.db

# ----- .NET / backend -----
**/[Bb]in/
**/[Oo]bj/
**/[Tt]est[Rr]esult*/
**/packages/
**/*.user
**/*.rsuser
**/*.suo
**/*.userosscache
**/*.sln.docstates
.global.json

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/repositories.config

# Visual Studio 
.vs/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Local user-specific files
appsettings.local.json
appsettings.dev.json
appsettings.qa.json
appsettings.stg.json
appsettings.prod.json

# Logs
*.log

# IDEs
.idea/
*.sublime-workspace
*.sublime-project

# stylish or tool-generated
generated/**

# Keep frontend ignore from existing frontend .gitignore in case this file is evaluated by CI
/frontend/node_modules/
/frontend/dist/
/frontend/out-tsc/
/frontend/.angular/cache/
/frontend/.sass-cache/
/frontend/.history/
/frontend/npm-debug.log
/frontend/yarn-error.log

# Keep backend ignore
/backend/**/[Bb]in/
/backend/**/[Oo]bj/
